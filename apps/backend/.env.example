# --- Base de données PostgreSQL ---
DATABASE_URL="postgresql://lasylab:lasylab@localhost:5432/lasylab?schema=public"

# --- Serveur ---
PORT=3000
# Origines autorisées pour le CORS (séparées par des virgules), * pour tout autoriser en dev
CORS_ORIGINS=*

# --- Auth JWT ---
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

# --- Groq (API compatible OpenAI) — LA CLÉ RESTE CÔTÉ SERVEUR, JAMAIS EXPOSÉE AU CLIENT ---
GROQ_API_KEY=""
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_MODEL="llama-3.3-70b-versatile"
