// Schéma Prisma — Lasylab
// Étape 1 : datasource + generator uniquement.
// Les modèles (users, subjects, lessons, quiz, results, sessions socratiques,
// progression, badges) seront définis à l'étape 2 (modélisation BDD).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
