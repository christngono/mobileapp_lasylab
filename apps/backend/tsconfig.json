{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "declaration": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "target": "ES2021",
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    // Pas de mapping paths ici : @lasylab/shared est résolu via node_modules
    // (paquet compilé), pour garder une sortie dist plate (dist/main.js).
    "paths": {}
  },
  "include": ["src/**/*", "prisma/**/*"]
}
